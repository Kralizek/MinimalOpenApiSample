@page "/"
@using System.Net.Http.Json
@using BookStore.Web.Models
@inject HttpClient Http

<PageTitle>Bookstore</PageTitle>

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0">Bookstore</h1>
        <button class="btn btn-primary" @onclick="CreateBookAsync" disabled="@isBusy">
            <i class="bi bi-plus-circle me-1"></i> Add Book
        </button>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-md-4">
            <label class="form-label">Title</label>
            <input class="form-control" @bind="newBook.Title" />
        </div>
        <div class="col-12 col-md-4">
            <label class="form-label">Author</label>
            <input class="form-control" @bind="newBook.Author" />
        </div>
        <div class="col-12 col-md-2">
            <label class="form-label">Price</label>
            <input class="form-control" type="number" min="0" step="0.01" @bind="newBook.Price" />
        </div>
        <div class="col-12 col-md-2">
            <label class="form-label">Category</label>
            <select class="form-select" @bind="selectedCategory">
                @foreach (var category in categories)
                {
                    <option value="@category">@category</option>
                }
            </select>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Author</th>
                    <th class="text-end">Price</th>
                    <th>Categories</th>
                </tr>
            </thead>
            <tbody>
                @if (books.Count == 0)
                {
                    <tr>
                        <td colspan="4" class="text-center py-4 text-muted">No books yet. Add your first one.</td>
                    </tr>
                }
                else
                {
                    @foreach (var book in books)
                    {
                        <tr>
                            <td>@book.Title</td>
                            <td>@book.Author</td>
                            <td class="text-end">@book.Price.ToString("C")</td>
                            <td>@string.Join(", ", book.Categories ?? [])</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private readonly List<BookDto> books = [];
    private readonly string[] categories = ["fiction", "non-fiction", "sci-fi", "fantasy"];
    private CreateBookRequest newBook = new();
    private string selectedCategory = "fiction";
    private bool isBusy;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadBooksAsync();
    }

    private async Task LoadBooksAsync()
    {
        isBusy = true;
        errorMessage = null;

        try
        {
            var response = await Http.GetFromJsonAsync<SearchBooksResponse>("/books");
            books.Clear();
            books.AddRange(response?.Items ?? []);
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not load books: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task CreateBookAsync()
    {
        if (string.IsNullOrWhiteSpace(newBook.Title) || string.IsNullOrWhiteSpace(newBook.Author))
        {
            errorMessage = "Title and author are required.";
            return;
        }

        isBusy = true;
        errorMessage = null;

        try
        {
            newBook.Categories = [selectedCategory];
            var response = await Http.PostAsJsonAsync("/books", newBook);
            response.EnsureSuccessStatusCode();

            newBook = new CreateBookRequest();
            await LoadBooksAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not create book: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }
}
