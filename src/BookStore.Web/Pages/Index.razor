@page "/"
@using System.Net.Http.Json
@using BookStore.Web.Models
@inject HttpClient Http

<PageTitle>Bookstore</PageTitle>

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0">Bookstore</h1>
        <button class="btn btn-primary" @onclick="CreateBookAsync" disabled="@isBusy">
            <i class="bi bi-plus-circle me-1"></i> Add Book
        </button>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-md-4">
            <label class="form-label">Title</label>
            <input class="form-control" @bind="newBook.Title" />
        </div>
        <div class="col-12 col-md-4">
            <label class="form-label">Author</label>
            <input class="form-control" @bind="newBook.Author" />
        </div>
        <div class="col-12 col-md-2">
            <label class="form-label">Price</label>
            <input class="form-control" type="number" min="0" step="0.01" @bind="newBook.Price" />
        </div>
        <div class="col-12 col-md-2">
            <label class="form-label">Category</label>
            <select class="form-select" @bind="selectedCategory">
                @foreach (var category in categories)
                {
                    <option value="@category">@GetCategoryLabel(category)</option>
                }
            </select>
        </div>
    </div>

    @if (editableBook is not null)
    {
        <div class="card mb-4">
            <div class="card-body">
                <h2 class="h5 mb-3">Edit Book</h2>
                <div class="row g-3">
                    <div class="col-12 col-md-4">
                        <label class="form-label">Title</label>
                        <input class="form-control" @bind="editableBook.Title" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label">Author</label>
                        <input class="form-control" @bind="editableBook.Author" />
                    </div>
                    <div class="col-12 col-md-2">
                        <label class="form-label">Price</label>
                        <input class="form-control" type="number" min="0" step="0.01" @bind="editableBook.Price" />
                    </div>
                    <div class="col-12 col-md-2">
                        <label class="form-label">Category</label>
                        <select class="form-select" @bind="selectedEditCategory">
                            @foreach (var category in categories)
                            {
                                <option value="@category">@GetCategoryLabel(category)</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="d-flex gap-2 mt-3">
                    <button class="btn btn-primary" @onclick="UpdateBookAsync" disabled="@isBusy">Save</button>
                    <button class="btn btn-outline-secondary" @onclick="CancelEdit" disabled="@isBusy">Cancel</button>
                </div>
            </div>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="alert alert-success">@successMessage</div>
    }

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Author</th>
                    <th class="text-end">Price</th>
                    <th>Categories</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (books.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">No books yet. Add your first one.</td>
                    </tr>
                }
                else
                {
                    @foreach (var book in books)
                    {
                        <tr>
                            <td>@book.Title</td>
                            <td>@book.Author</td>
                            <td class="text-end">@book.Price.ToString("C")</td>
                            <td>@string.Join(", ", (book.Categories ?? []).Select(GetCategoryLabel))</td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm">
                                    <button class="btn btn-outline-primary" @onclick="() => BeginEdit(book)" disabled="@isBusy">Edit</button>
                                    <button class="btn btn-outline-danger" @onclick="() => DeleteBookAsync(book.Id)" disabled="@isBusy">Delete</button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private readonly List<BookDto> books = [];
    private readonly Category[] categories = [Category.Fiction, Category.NonFiction, Category.SciFi, Category.Fantasy];
    private CreateBookRequest newBook = new();
    private Category selectedCategory = Category.Fiction;
    private EditableBook? editableBook;
    private Category selectedEditCategory = Category.Fiction;
    private bool isBusy;
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadBooksAsync();
    }

    private async Task LoadBooksAsync()
    {
        isBusy = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var response = await Http.GetFromJsonAsync<SearchBooksResponse>("/books");
            books.Clear();
            books.AddRange(response?.Items ?? []);
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not load books: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task CreateBookAsync()
    {
        if (string.IsNullOrWhiteSpace(newBook.Title) || string.IsNullOrWhiteSpace(newBook.Author))
        {
            errorMessage = "Title and author are required.";
            return;
        }

        isBusy = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            newBook.Categories = [selectedCategory];
            var response = await Http.PostAsJsonAsync("/books", newBook);
            response.EnsureSuccessStatusCode();

            newBook = new CreateBookRequest();
            await LoadBooksAsync();
            successMessage = "Book created.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not create book: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private void BeginEdit(BookDto book)
    {
        editableBook = new EditableBook
        {
            Id = book.Id,
            Title = book.Title,
            Author = book.Author,
            Price = book.Price,
            Isbn = book.Isbn
        };

        selectedEditCategory = book.Categories?.FirstOrDefault() ?? Category.Fiction;
        errorMessage = null;
        successMessage = null;
    }

    private void CancelEdit()
    {
        editableBook = null;
        selectedEditCategory = Category.Fiction;
    }

    private async Task UpdateBookAsync()
    {
        if (editableBook is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(editableBook.Title) || string.IsNullOrWhiteSpace(editableBook.Author))
        {
            errorMessage = "Title and author are required.";
            return;
        }

        isBusy = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var request = new UpdateBookRequest
            {
                Title = editableBook.Title,
                Author = editableBook.Author,
                Price = editableBook.Price,
                Isbn = editableBook.Isbn,
                Categories = [selectedEditCategory]
            };

            var response = await Http.PutAsJsonAsync($"/books/{editableBook.Id}", request);
            response.EnsureSuccessStatusCode();

            editableBook = null;
            selectedEditCategory = Category.Fiction;
            await LoadBooksAsync();
            successMessage = "Book updated.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not update book: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task DeleteBookAsync(Guid id)
    {
        isBusy = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var response = await Http.DeleteAsync($"/books/{id}");
            response.EnsureSuccessStatusCode();

            if (editableBook?.Id == id)
            {
                editableBook = null;
                selectedEditCategory = Category.Fiction;
            }

            await LoadBooksAsync();
            successMessage = "Book deleted.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not delete book: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private sealed class EditableBook
    {
        public Guid Id { get; init; }

        public string Title { get; set; } = string.Empty;

        public string Author { get; set; } = string.Empty;

        public double Price { get; set; }

        public string? Isbn { get; set; }
    }

    private static string GetCategoryLabel(Category category)
    {
        return category switch
        {
            Category.Fiction => "Fiction",
            Category.NonFiction => "Non-Fiction",
            Category.SciFi => "Sci-Fi",
            Category.Fantasy => "Fantasy",
            _ => category.ToString()
        };
    }
}
